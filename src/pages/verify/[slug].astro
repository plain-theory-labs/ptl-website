---
import BaseLayout from "../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return [{ params: { slug: "index" } }];
}

const { slug } = Astro.params;
const description = "Assessment record lookup — Plain Theory Labs";
---

<BaseLayout title="Assessment record lookup — Plain Theory Labs" description={description}>
  <section class="section prose">
    <h1>Assessment record lookup</h1>

    <p>
      This page will show a public assessment record when an organization chooses
      to publish one. Contact <a href="mailto:research@plaintheory.org">research@plaintheory.org</a>
      to review a report ID.
    </p>
  </section>
</BaseLayout>
