---
import BaseLayout from "../layouts/BaseLayout.astro";

const description = "Contact Plain Theory Labs.";
const email = "hello@plaintheorylabs.org";
---

<BaseLayout title="Contact | Plain Theory Labs" description={description}>
  <section class="section prose">
    <h1>Contact</h1>
    <p>
      We welcome research and engineering collaboration around trace-based infrastructure analysis. Send a short note
      with the context you have, and we can discuss whether a reproducible pass is feasible.
    </p>

    <ul>
      <li>scheduler type and approximate job volume</li>
      <li>timeframe available for analysis</li>
      <li>available signals (GPU utilization, memory, power, or proxies)</li>
    </ul>

    <hr class="rule" />

    <form id="contact-form">
      <label for="email">Your email</label>
      <input id="email" name="email" type="email" required placeholder="you@organization.com" />

      <label for="message">Message</label>
      <textarea
        id="message"
        name="message"
        required
        placeholder="Scheduler, workload size, timeframe, and available signals."
      ></textarea>

      <button type="submit">Open email draft</button>
    </form>

    <p class="muted">Direct email: <a href={`mailto:${email}`}>{email}</a></p>
  </section>

  <script is:inline>
    const form = document.getElementById("contact-form");
    if (form) {
      form.addEventListener("submit", (event) => {
        event.preventDefault();
        const emailField = document.getElementById("email");
        const messageField = document.getElementById("message");
        const from = emailField instanceof HTMLInputElement ? emailField.value.trim() : "";
        const message = messageField instanceof HTMLTextAreaElement ? messageField.value.trim() : "";
        const subject = encodeURIComponent("Plain Theory Labs note");
        const body = encodeURIComponent(`From: ${from}\n\n${message}`);
        window.location.href = `mailto:${"hello@plaintheorylabs.org"}?subject=${subject}&body=${body}`;
      });
    }
  </script>
</BaseLayout>
