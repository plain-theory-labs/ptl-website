---
import BaseLayout from "../layouts/BaseLayout.astro";

const description = "Contact Plain Theory Labs.";
---

<BaseLayout title="Contact | Plain Theory Labs" description={description}>
  <section class="section prose">
    <h1>Get in touch</h1>

    <p>
      We are taking three pilot organizations this quarter. A pilot begins with
      a Slurm scheduler export and four questions about your facility. We run
      the analysis and deliver a private certification report to your team.
      The data collection takes under two hours.
    </p>

    <p>
      Write to us at <a href="mailto:jesus@plaintheory.org">jesus@plaintheory.org</a>.
    </p>
  </section>
</BaseLayout>
