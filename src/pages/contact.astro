---
import BaseLayout from "../layouts/BaseLayout.astro";

const description = "Work with us — Plain Theory Labs";
---

<BaseLayout title="Work with us — Plain Theory Labs" description={description}>
  <div class="wrap">
    <div class="section" id="pilot">
      <span class="section-label">Work with us</span>
      <div class="contact-body">
        <p>We are taking three pilots this quarter.
The findings belong to your organization.
We keep the methodology.</p>
        <a href="mailto:research@plaintheory.org"
           class="contact-email">research@plaintheory.org</a>
      </div>
    </div>
    <footer>
      <span>Plain Theory Labs</span>
      <span>2026</span>
    </footer>
  </div>
</BaseLayout>
