---
import BaseLayout from "../layouts/BaseLayout.astro";

const description = "Assessment badges — Plain Theory Labs";

const tiers = [
  { name: "FRONTIER",   slug: "frontier" },
  { name: "OPTIMIZED",  slug: "optimized" },
  { name: "CAPABLE",    slug: "capable" },
  { name: "DEVELOPING", slug: "developing" },
  { name: "BASELINE",   slug: "baseline" },
  { name: "PENDING",    slug: "pending" },
];
---

<BaseLayout title="Assessment badges — Plain Theory Labs" description={description}>
  <section class="section prose">
    <h1>Assessment badges</h1>

    <p class="thesis">
      Organizations may display a PTL assessment badge on their website after
      choosing to publish a report. Badges link to plaintheory.org and show the assessment tier
      and period.
    </p>

    <hr class="rule" />

    {tiers.map((tier) => (
      <div class="badge-row">
        <img
          src={`/badges/ptl-assessment-${tier.slug}.svg`}
          alt={`PTL ${tier.name} Assessment`}
          width="200"
          height="80"
          class="badge-preview"
        />
        <p class="badge-label">{tier.name}</p>
        <pre class="badge-code"><code>{`<a href="https://plaintheory.org">
  <img src="https://plaintheory.org/badges/ptl-assessment-${tier.slug}.svg"
       alt="PTL ${tier.name} Assessment [YEAR]"
       width="200" height="80">
</a>`}</code></pre>
      </div>
    ))}

  </section>
</BaseLayout>

<style>
  .badge-row {
    margin-bottom: 3rem;
    max-width: var(--prose);
  }
  .badge-preview {
    display: block;
    margin-bottom: 0.5rem;
  }
  .badge-label {
    font-size: var(--text-sm);
    color: var(--muted);
    margin-bottom: 0.5rem;
  }
  .badge-code {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.75rem 1rem;
    font-size: 0.8rem;
    overflow-x: auto;
    white-space: pre;
    margin: 0;
  }
  .badge-code code {
    background: none;
    padding: 0;
    font-size: inherit;
  }
</style>
