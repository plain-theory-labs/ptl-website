---
import BaseLayout from "../layouts/BaseLayout.astro";

const description = "Assessment — Plain Theory Labs";
---

<BaseLayout title="Assessment — Plain Theory Labs" description={description}>
  <div class="wrap">
    <div class="section">
      <span class="section-label">Assessment</span>
      <div class="contact-body">
        <p>The PTL assessment process, tier structure, and longitudinal record are fully documented. A score between 0.0 and 1.0. One tier. Your findings.</p>
        <a href="/docs/certification/" class="contact-email">Read how assessment works</a>
      </div>
    </div>
    <footer>
      <span>Plain Theory Labs</span>
      <span>2026</span>
    </footer>
  </div>
</BaseLayout>
