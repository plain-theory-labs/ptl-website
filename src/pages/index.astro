---
import BaseLayout from "../layouts/BaseLayout.astro";

const description =
  "Plain Theory Labs — certification framework for sustainable AI compute infrastructure";
---

<BaseLayout title="Plain Theory Labs — certification framework for sustainable AI compute infrastructure" description={description}>

  <section class="hero">
    <div class="hero-inner">

      <span class="hero-tag">Plain Theory Labs</span>

      <h1>An independent certification framework
for AI compute infrastructure.</h1>

      <p class="hero-sub">
        We measure what GPU clusters are actually doing,
        score it against a documented methodology, and
        deliver findings against a published standard.
        Nine analytical engines. One score. One tier.
      </p>

      <div class="score-strip" style="margin: 56px 0 0; padding: 32px 0 0; border-top: 0.5px solid #1e1e1e;">
        <div class="score-strip-inner" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; padding: 0;">
          <div class="score-item">
            <span class="score-value frontier">0.873</span>
            <span class="score-meta">FRONTIER<br/>NERSC Perlmutter</span>
          </div>
          <div class="score-item">
            <span class="score-value optimized">0.814</span>
            <span class="score-meta">OPTIMIZED<br/>Meridian AI</span>
          </div>
          <div class="score-item">
            <span class="score-value optimized">0.736</span>
            <span class="score-meta">OPTIMIZED<br/>OLCF Frontier</span>
          </div>
          <div class="score-item">
            <span class="score-value developing">0.450</span>
            <span class="score-meta">DEVELOPING<br/>MIT Supercloud</span>
          </div>
        </div>
      </div>

      <div style="margin-top: 52px; display: flex;
                  gap: 32px; align-items: center;
                  border-top: 0.5px solid #1e1e1e;
                  padding-top: 28px;">
        <a href="mailto:jesus@plaintheory.org"
           class="cta-link-light">Start a pilot</a>
        <a href="/docs"
           class="cta-link-light"
           style="color: #7ab8a8;
                  border-bottom-color: #2a4a44;">
          Documentation →
        </a>
        <span style="font-family: var(--mono);
                     font-size: 10px;
                     color: #555;
                     letter-spacing: 1px;
                     margin-left: auto;">
          jesus@plaintheory.org
        </span>
      </div>

    </div>
  </section>

</BaseLayout>
