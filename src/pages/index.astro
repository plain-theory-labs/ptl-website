      <line x1="16" y1="35" x2="16" y2="39" stroke="#94918a" stroke-width="1.1" stroke-linecap="round" opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.1s" fill="freeze" begin="0.65s"/></line>
      <line x1="22" y1="35" x2="22" y2="39" stroke="#94918a" stroke-width="1.1" stroke-linecap="round" opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.1s" fill="freeze" begin="0.7s"/></line>
      <line x1="28" y1="35" x2="28" y2="39" stroke="#94918a" stroke-width="1.1" stroke-linecap="round" opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.1s" fill="freeze" begin="0.75s"/></line>
