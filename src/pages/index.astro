---
import BaseLayout from "../layouts/BaseLayout.astro";

const description = "One honest score for AI compute infrastructure.";
---

<BaseLayout title="Plain Theory Labs" description={description}>

<section class="hero">

  <div class="statement">
    <span class="hero-eyebrow">Plain Theory Labs</span>
    <h1>One honest score for AI compute infrastructure.</h1>
    <p class="hero-sub">
  AI infrastructure should perform at the level of the science it supports.
</p>
  </div>

  <div class="hero-data">

    <div class="score-list">
      <div class="score-row">
        <span class="score-label">MIT Supercloud</span>
        <span class="score-val score-val--anim">0.000</span>
      </div>
      <div class="score-row">
        <span class="score-label">Alibaba Helios 2020</span>
        <span class="score-val score-val--anim">0.000</span>
      </div>
      <div class="score-row">
        <span class="score-label">Microsoft Philly 2017</span>
        <span class="score-val score-val--anim">0.000</span>
      </div>
    </div>

    <span class="scale-note">GPU Efficiency · 0.0 to 1.0 · <span class="total-jobs-count">0</span> jobs validated across 3 peer-reviewed datasets</span>

    <div class="actions">
      <a href="#pilot" class="cta cta-primary">Start a pilot</a>
      <a href="/docs" class="cta cta-docs">Read the documentation</a>
    </div>

  </div>

</section>

<div class="wrap">

  <div class="section" id="engines">
    <span class="section-label">The framework</span>

    <div class="engine-list" id="engineList">

  <!-- PROFILE -->
  <div class="engine" data-engine-idx="0">
    <span class="engine-name">PROFILE</span>
    <svg class="engine-icon engine-icon-profile" viewBox="0 0 52 52" fill="none">
      <!-- Gear — 8 teeth, clean rectangular form, centered -->
      <path d="
        M23 5 L29 5 L29 9.5
        C32 10 34.5 11.5 36.5 13.5 L40.5 11.5 L44.5 15.5 L42.5 19.5
        C43.5 21.5 44 23.5 44 26
        L48 26 L48 32 L44 32
        C44 34.5 43.5 36.5 42.5 38.5 L44.5 42.5 L40.5 46.5 L36.5 44.5
        C34.5 46.5 32 48 29 48.5 L29 52 L23 52 L23 48.5
        C20 48 17.5 46.5 15.5 44.5 L11.5 46.5 L7.5 42.5 L9.5 38.5
        C8.5 36.5 8 34.5 8 32 L4 32 L4 26 L8 26
        C8 23.5 8.5 21.5 9.5 19.5 L7.5 15.5 L11.5 11.5 L15.5 13.5
        C17.5 11.5 20 10 23 9.5 Z"
        stroke="#28251e" stroke-width="1.4" fill="none"
        stroke-dasharray="220" stroke-dashoffset="220">
        <animate attributeName="stroke-dashoffset" from="220" to="0" dur="1.0s" fill="freeze" begin="0.05s" calcMode="spline" keySplines="0.4 0 0.2 1"/>
      </path>
      <!-- Inner circle -->
      <circle cx="26" cy="28.5" r="9"
        stroke="#28251e" stroke-width="1.2" fill="none"
        stroke-dasharray="56" stroke-dashoffset="56">
        <animate attributeName="stroke-dashoffset" from="56" to="0" dur="0.4s" fill="freeze" begin="1.05s"/>
      </circle>
      <!-- Subtle green fill -->
      <circle cx="26" cy="28.5" r="9" fill="#14532d" opacity="0">
        <animate attributeName="opacity" from="0" to="0.15" dur="0.25s" fill="freeze" begin="1.45s"/>
      </circle>
      <!-- Center hub -->
      <circle cx="26" cy="28.5" r="3" fill="#14532d" opacity="0">
        <animate attributeName="opacity" from="0" to="1" dur="0.2s" fill="freeze" begin="1.48s"/>
      </circle>
    </svg>
    <div class="engine-body">
      <p class="engine-title">The cluster characterizes itself first.</p>
      <p class="engine-desc">PROFILE runs before any other engine. It identifies the scheduler, hardware, and workload types in use — then routes each engine to the highest-fidelity data source available. Everything that follows depends on what PROFILE finds.</p>
    </div>
  </div>

  <!-- ACE -->
  <div class="engine" data-engine-idx="1">
    <span class="engine-name">ACE</span>
    <svg class="engine-icon" viewBox="0 0 44 44" fill="none">
      <rect x="9" y="9" width="26" height="26" rx="2" stroke="#28251e" stroke-width="1.4" fill="none" stroke-dasharray="104" stroke-dashoffset="104"><animate attributeName="stroke-dashoffset" from="104" to="0" dur="0.55s" fill="freeze" begin="0.05s"/></rect>
      <line x1="9" y1="16" x2="5" y2="16" stroke="#94918a" stroke-width="1.1" stroke-linecap="round" opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.1s" fill="freeze" begin="0.65s"/></line>
      <line x1="9" y1="22" x2="5" y2="22" stroke="#94918a" stroke-width="1.1" stroke-linecap="round" opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.1s" fill="freeze" begin="0.7s"/></line>
      <line x1="9" y1="28" x2="5" y2="28" stroke="#94918a" stroke-width="1.1" stroke-linecap="round" opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.1s" fill="freeze" begin="0.75s"/></line>
      <line x1="35" y1="16" x2="39" y2="16" stroke="#94918a" stroke-width="1.1" stroke-linecap="round" opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.1s" fill="freeze" begin="0.65s"/></line>
      <line x1="35" y1="22" x2="39" y2="22" stroke="#94918a" stroke-width="1.1" stroke-linecap="round" opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.1s" fill="freeze" begin="0.7s"/></line>
      <line x1="35" y1="28" x2="39" y2="28" stroke="#94918a" stroke-width="1.1" stroke-linecap="round" opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.1s" fill="freeze" begin="0.75s"/></line>
      <line x1="16" y1="9" x2="16" y2="5" stroke="#94918a" stroke-width="1.1" stroke-linecap="round" opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.1s" fill="freeze" begin="0.65s"/></line>
      <line x1="22" y1="9" x2="22" y2="5" stroke="#94918a" stroke-width="1.1" stroke-linecap="round" opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.1s" fill="freeze" begin="0.7s"/></line>
      <line x1="28" y1="9" x2="28" y2="5" stroke="#94918a" stroke-width="1.1" stroke-linecap="round" opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.1s" fill="freeze" begin="0.75s"/></line>
      <line x1="16" y1="35" x2="16" y2="39" stroke="#94918a" stroke-width="1.1" stroke-linecap="round" opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.1s" fill="freeze" begin="0.65s"/></line>
      <line x1="22" y1="35" x2="22" y2="39" stroke="#94918a" stroke-width="1.1" stroke-linecap="round" opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.1s" fill="freeze" begin="0.7s"/></line>
      <line x1="28" y1="35" x2="28" y2="39" stroke="#94918a" stroke-width="1.1" stroke-linecap="round" opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.1s" fill="freeze" begin="0.75s"/></line>
      <rect x="16" y="16" width="12" height="12" rx="1" stroke="#94918a" stroke-width="1" fill="none" opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.2s" fill="freeze" begin="0.85s"/></rect>
      <rect x="16" y="16" width="12" height="12" rx="1" fill="#14532d" opacity="0"><animate attributeName="opacity" from="0" to="0.22" dur="0.3s" fill="freeze" begin="1.0s"/></rect>
    </svg>
    <div class="engine-body">
      <p class="engine-title">GPU utilization, measured honestly.</p>
      <p class="engine-desc">Of the GPU capacity allocated to each workload, how much was actually used? The answer is almost always surprising. ACE finds the gap between what was requested and what ran.</p>
    </div>
  </div>

  <!-- COOL -->
  <div class="engine" data-engine-idx="2">
    <span class="engine-name">COOL</span>
    <svg class="engine-icon" viewBox="0 0 44 44" fill="none">
      <line x1="22" y1="8" x2="22" y2="31" stroke="#28251e" stroke-width="1.4" stroke-linecap="round" stroke-dasharray="23" stroke-dashoffset="23"><animate attributeName="stroke-dashoffset" from="23" to="0" dur="0.4s" fill="freeze" begin="0.05s"/></line>
      <circle cx="22" cy="35" r="4.5" stroke="#28251e" stroke-width="1.4" fill="none" stroke-dasharray="29" stroke-dashoffset="29"><animate attributeName="stroke-dashoffset" from="29" to="0" dur="0.38s" fill="freeze" begin="0.42s"/></circle>
      <circle cx="22" cy="35" r="3" fill="#0e7490" opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.22s" fill="freeze" begin="0.78s"/></circle>
      <line x1="22" y1="30" x2="22" y2="30" stroke="#0e7490" stroke-width="2.2" stroke-linecap="round"><animate attributeName="y2" from="30" to="17" dur="0.55s" fill="freeze" begin="0.9s" calcMode="spline" keySplines="0.4 0 0.2 1"/></line>
      <line x1="25" y1="21" x2="27" y2="21" stroke="#94918a" stroke-width="0.75" opacity="0"><animate attributeName="opacity" from="0" to="0.7" dur="0.12s" fill="freeze" begin="1.38s"/></line>
      <line x1="25" y1="25" x2="27" y2="25" stroke="#94918a" stroke-width="0.75" opacity="0"><animate attributeName="opacity" from="0" to="0.7" dur="0.12s" fill="freeze" begin="1.43s"/></line>
      <line x1="25" y1="29" x2="27" y2="29" stroke="#94918a" stroke-width="0.75" opacity="0"><animate attributeName="opacity" from="0" to="0.7" dur="0.12s" fill="freeze" begin="1.48s"/></line>
    </svg>
    <div class="engine-body">
      <p class="engine-title">Energy in versus useful work out.</p>
      <p class="engine-desc">Cooling is the largest non-compute energy cost in most facilities. COOL grades thermal efficiency against what is genuinely achievable for this facility type and climate — not an industry average.</p>
    </div>
  </div>

  <!-- FLUX -->
  <div class="engine" data-engine-idx="3">
    <span class="engine-name">FLUX</span>
    <svg class="engine-icon" viewBox="0 0 44 44" fill="none">
      <rect x="7" y="9" width="30" height="26" rx="2.5" stroke="#14532d" stroke-width="1.4" fill="none" stroke-dasharray="112" stroke-dashoffset="112"><animate attributeName="stroke-dashoffset" from="112" to="0" dur="0.6s" fill="freeze" begin="0.05s"/></rect>
      <rect x="12" y="14" width="20" height="10" rx="1.2" fill="#14532d" opacity="0"><animate attributeName="opacity" from="0" to="0.1" dur="0.2s" fill="freeze" begin="0.7s"/></rect>
      <rect x="14" y="16" width="4" height="6" rx="0.5" fill="#14532d" opacity="0"><animate attributeName="opacity" from="0" to="0.85" dur="0.13s" fill="freeze" begin="0.9s"/></rect>
      <rect x="20" y="16" width="4" height="6" rx="0.5" fill="#14532d" opacity="0"><animate attributeName="opacity" from="0" to="0.85" dur="0.13s" fill="freeze" begin="1.0s"/></rect>
      <rect x="26" y="16" width="4" height="6" rx="0.5" fill="#14532d" opacity="0"><animate attributeName="opacity" from="0" to="0.85" dur="0.13s" fill="freeze" begin="1.1s"/></rect>
      <text x="22" y="32" font-family="monospace" font-size="6.5" fill="#14532d" text-anchor="middle" opacity="0"><animate attributeName="opacity" from="0" to="0.8" dur="0.2s" fill="freeze" begin="1.2s"/>kWh</text>
      <line x1="18" y1="9" x2="18" y2="5" stroke="#14532d" stroke-width="1" stroke-linecap="round" opacity="0"><animate attributeName="opacity" from="0" to="0.6" dur="0.15s" fill="freeze" begin="0.8s"/></line>
      <line x1="26" y1="9" x2="26" y2="5" stroke="#14532d" stroke-width="1" stroke-linecap="round" opacity="0"><animate attributeName="opacity" from="0" to="0.6" dur="0.15s" fill="freeze" begin="0.85s"/></line>
    </svg>
    <div class="engine-body">
      <p class="engine-title">Is the carbon accounting actually traceable?</p>
      <p class="engine-desc">Carbon accounting in AI infrastructure ranges from rigorous to meaningless. FLUX grades the methodology and detects when claimed renewable coverage cannot be traced from grid to certificate to claim.</p>
    </div>
  </div>

  <!-- PACE -->
  <div class="engine" data-engine-idx="4">
    <span class="engine-name">PACE</span>
    <svg class="engine-icon" viewBox="0 0 44 44" fill="none">
      <rect x="7" y="9" width="9" height="8" rx="1" fill="#14532d" opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.13s" fill="freeze" begin="0.15s"/></rect>
      <rect x="18" y="9" width="9" height="8" rx="1" fill="#14532d" opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.13s" fill="freeze" begin="0.25s"/></rect>
      <rect x="29" y="9" width="9" height="8" rx="1" fill="#14532d" opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.13s" fill="freeze" begin="0.35s"/></rect>
      <rect x="7" y="20" width="9" height="8" rx="1" fill="#14532d" opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.13s" fill="freeze" begin="0.45s"/></rect>
      <rect x="18" y="20" width="9" height="8" rx="1" fill="#ccc8be" opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.13s" fill="freeze" begin="0.55s"/></rect>
      <rect x="29" y="20" width="9" height="8" rx="1" fill="#14532d" opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.13s" fill="freeze" begin="0.65s"/></rect>
      <rect x="7" y="31" width="9" height="8" rx="1" fill="#ccc8be" opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.13s" fill="freeze" begin="0.75s"/></rect>
      <rect x="18" y="31" width="9" height="8" rx="1" fill="#92400e" opacity="0"><animate attributeName="opacity" from="0" to="0.75" dur="0.13s" fill="freeze" begin="0.85s"/></rect>
      <rect x="29" y="31" width="9" height="8" rx="1" fill="#14532d" opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.13s" fill="freeze" begin="0.95s"/></rect>
    </svg>
    <div class="engine-body">
      <p class="engine-title">The decisions made before work starts.</p>
      <p class="engine-desc">Scheduler policy determines how compute gets allocated before a single workload runs. PACE grades those decisions and finds the patterns that leave hardware waiting: over-requesting, poor backfill, fairshare imbalance.</p>
    </div>
  </div>

  <!-- CORE -->
  <div class="engine" data-engine-idx="5">
    <span class="engine-name">CORE</span>
    <svg class="engine-icon" viewBox="0 0 44 44" fill="none">
      <!-- Rack frame — tall narrow rectangle, server rack shape -->
      <rect x="12" y="4" width="20" height="36" rx="1.5"
        stroke="#28251e" stroke-width="1.4" fill="none"
        stroke-dasharray="112" stroke-dashoffset="112">
        <animate attributeName="stroke-dashoffset" from="112" to="0" dur="0.6s" fill="freeze" begin="0.05s"/>
      </rect>
      <!-- Slot 1 — green, running well -->
      <rect x="15" y="8" width="14" height="4" rx="0.5" fill="#14532d" opacity="0">
        <animate attributeName="opacity" from="0" to="0.9" dur="0.12s" fill="freeze" begin="0.7s"/>
      </rect>
      <!-- Slot 2 — green -->
      <rect x="15" y="15" width="14" height="4" rx="0.5" fill="#14532d" opacity="0">
        <animate attributeName="opacity" from="0" to="0.9" dur="0.12s" fill="freeze" begin="0.82s"/>
      </rect>
      <!-- Slot 3 — green -->
      <rect x="15" y="22" width="14" height="4" rx="0.5" fill="#14532d" opacity="0">
        <animate attributeName="opacity" from="0" to="0.9" dur="0.12s" fill="freeze" begin="0.94s"/>
      </rect>
      <!-- Slot 4 — amber, wrong workload for this hardware -->
      <rect x="15" y="29" width="14" height="4" rx="0.5" fill="#92400e" opacity="0">
        <animate attributeName="opacity" from="0" to="0.8" dur="0.12s" fill="freeze" begin="1.06s"/>
      </rect>
      <!-- Slot 5 — empty -->
      <rect x="15" y="36" width="14" height="4" rx="0.5" fill="#dedad2" opacity="0">
        <animate attributeName="opacity" from="0" to="1" dur="0.12s" fill="freeze" begin="1.18s"/>
      </rect>
      <!-- Amber dot — flags the mismatch slot -->
      <circle cx="27" cy="31" r="1.2" fill="#92400e" opacity="0">
        <animate attributeName="opacity" from="0" to="1" dur="0.15s" fill="freeze" begin="1.22s"/>
      </circle>
    </svg>
    <div class="engine-body">
      <p class="engine-title">Is this the right hardware for this work?</p>
      <p class="engine-desc">A cluster optimized for training in 2021 may be the wrong tool for inference in 2026. CORE grades hardware-to-workload fit, fleet age, and whether the infrastructure was designed for what it is actually running.</p>
    </div>
  </div>

  <!-- GRADE -->
  <div class="engine" data-engine-idx="6">
    <span class="engine-name">GRADE</span>
    <svg class="engine-icon" viewBox="0 0 44 44" fill="none">
      <rect x="6" y="19" width="32" height="10" rx="5" fill="#dedad2"/>
      <clipPath id="grade-clip">
        <rect x="6" y="19" width="0" height="10" rx="5">
          <animate attributeName="width" from="0" to="28" dur="1.1s" fill="freeze" begin="0.2s" calcMode="spline" keySplines="0.4 0 0.2 1"/>
        </rect>
      </clipPath>
      <rect x="6" y="19" width="32" height="10" rx="5" fill="#14532d" clip-path="url(#grade-clip)"/>
      <text x="20" y="27" font-family="monospace" font-size="7.5" fill="#dcfce7" text-anchor="middle" font-weight="500" opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.3s" fill="freeze" begin="1.1s"/>0.873</text>
      <line x1="33" y1="17" x2="33" y2="19" stroke="#94918a" stroke-width="1" opacity="0"><animate attributeName="opacity" from="0" to="0.6" dur="0.2s" fill="freeze" begin="1.3s"/></line>
      <text x="33" y="14" font-family="monospace" font-size="5.5" fill="#94918a" text-anchor="middle" opacity="0"><animate attributeName="opacity" from="0" to="0.5" dur="0.2s" fill="freeze" begin="1.35s"/>0.85</text>
    </svg>
    <div class="engine-body">
      <p class="engine-title">Five engines become one number.</p>
      <p class="engine-desc">GRADE weighs what every engine found and produces a PTL Score between 0.0 and 1.0. The weights are published. The formula is deterministic. The same inputs always produce the same number. The engine source is public.</p>
    </div>
  </div>

  <!-- ATLAS -->
  <div class="engine" data-engine-idx="7">
    <span class="engine-name">ATLAS</span>
    <svg class="engine-icon" viewBox="0 0 44 44" fill="none">
      <rect x="13" y="8" width="26" height="8" rx="1" fill="#14532d" opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.18s" fill="freeze" begin="0.15s"/></rect>
      <text x="9" y="14.5" font-family="monospace" font-size="8.5" fill="#14532d" font-weight="500" text-anchor="end" opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.18s" fill="freeze" begin="0.18s"/>1</text>
      <rect x="13" y="20" width="19" height="8" rx="1" fill="#334155" opacity="0"><animate attributeName="opacity" from="0" to="0.75" dur="0.18s" fill="freeze" begin="0.42s"/></rect>
      <text x="9" y="26.5" font-family="monospace" font-size="8.5" fill="#94918a" text-anchor="end" opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.18s" fill="freeze" begin="0.45s"/>2</text>
      <rect x="13" y="32" width="12" height="8" rx="1" fill="#94918a" opacity="0"><animate attributeName="opacity" from="0" to="0.5" dur="0.18s" fill="freeze" begin="0.7s"/></rect>
      <text x="9" y="38.5" font-family="monospace" font-size="8.5" fill="#94918a" text-anchor="end" opacity="0"><animate attributeName="opacity" from="0" to="0.7" dur="0.18s" fill="freeze" begin="0.73s"/>3</text>
    </svg>
    <div class="engine-body">
      <p class="engine-title">Ranked by impact, not difficulty.</p>
      <p class="engine-desc">A score is only useful if it points somewhere. ATLAS ranks the changes most likely to improve the next assessment. Every recommendation is specific to this cluster and this workload profile. No generic advice.</p>
    </div>
  </div>

  <!-- CLAW -->
  <div class="engine engine-claw" data-engine-idx="8">
    <span class="engine-name">CLAW</span>
    <svg class="engine-icon" viewBox="0 0 44 44" fill="none">
      <path d="M7 40 C7 33 9 26 14 21 C18 17 23 15 28 17 C34 19 37 25 35 31 C33 36 28 40 21 40 Z"
        stroke="#0e7490" stroke-width="1.6" fill="none"
        stroke-dasharray="100" stroke-dashoffset="100">
        <animate attributeName="stroke-dashoffset" from="100" to="0" dur="0.62s" fill="freeze" begin="0.08s" calcMode="spline" keySplines="0.4 0 0.2 1"/>
      </path>
      <path d="M7 40 C7 33 9 26 14 21 C18 17 23 15 28 17 C34 19 37 25 35 31 C33 36 28 40 21 40 Z"
        fill="#0e7490" opacity="0">
        <animate attributeName="opacity" from="0" to="0.1" dur="0.22s" fill="freeze" begin="0.7s"/>
      </path>
      <path d="M35 31 C37 27 39 22 39 18 C39 14 36 11 33 12 C30 13 29 16 30 19"
        stroke="#0e7490" stroke-width="1.6" fill="none" stroke-linecap="round"
        stroke-dasharray="38" stroke-dashoffset="38">
        <animate attributeName="stroke-dashoffset" from="38" to="0" dur="0.38s" fill="freeze" begin="0.72s" calcMode="spline" keySplines="0.4 0 0.2 1"/>
      </path>
      <path d="M28 17 C32 13 38 10 41 12 C44 14 44 18 42 21 C40 24 37 24 34 23"
        stroke="#0e7490" stroke-width="1.6" fill="none" stroke-linecap="round"
        stroke-dasharray="36" stroke-dashoffset="36">
        <animate attributeName="stroke-dashoffset" from="36" to="0" dur="0.36s" fill="freeze" begin="0.98s" calcMode="spline" keySplines="0.4 0 0.2 1"/>
      </path>
      <circle cx="28" cy="17" r="2" fill="#0e7490" opacity="0">
        <animate attributeName="opacity" from="0" to="1" dur="0.18s" fill="freeze" begin="1.02s"/>
      </circle>
      <path d="M30 19 C31 20 32 21 32 22 C32 23 31 23 30 22"
        stroke="#0e7490" stroke-width="0.9" fill="none" opacity="0">
        <animate attributeName="opacity" from="0" to="0.65" dur="0.18s" fill="freeze" begin="1.32s"/>
      </path>
      <path d="M16 28 C19 26 23 25 27 26"
        stroke="#0e7490" stroke-width="0.65" fill="none" opacity="0">
        <animate attributeName="opacity" from="0" to="0.38" dur="0.18s" fill="freeze" begin="1.15s"/>
      </path>
    </svg>
    <div class="engine-body">
      <p class="engine-title">The cluster describes itself.</p>
