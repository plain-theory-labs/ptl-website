<script>
(function() {
  function easeOutQuart(t) {
    return 1 - Math.pow(1 - t, 4);
  }

  function animateFloat(el, target, duration, delay) {
    el.textContent = '0.000';
    setTimeout(function() {
      var start = null;
      function step(timestamp) {
        if (!start) start = timestamp;
        var progress = Math.min((timestamp - start) / duration, 1);
        el.textContent = (easeOutQuart(progress) * target).toFixed(3);
        if (progress < 1) requestAnimationFrame(step);
        else el.textContent = target.toFixed(3);
      }
      requestAnimationFrame(step);
    }, delay);
  }

  function animateInteger(el, target, duration, delay) {
    el.textContent = '0';
    setTimeout(function() {
      var start = null;
      function step(timestamp) {
        if (!start) start = timestamp;
        var progress = Math.min((timestamp - start) / duration, 1);
        el.textContent = Math.round(easeOutQuart(progress) * target).toLocaleString();
        if (progress < 1) requestAnimationFrame(step);
        else el.textContent = target.toLocaleString();
      }
      requestAnimationFrame(step);
    }, delay);
  }

  function runAnimation() {
    var rows    = document.querySelectorAll('.score-val--anim');
    var totalEl = document.querySelector('.total-jobs-count');
    var targets = [0.339, 0.214, 0.502];

    rows.forEach(function(el, i) {
      animateFloat(el, targets[i], 1500, i * 120);
    });
    if (totalEl) animateInteger(totalEl, 508885, 1400, 500);
  }

  // Prevent flash
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.score-val--anim')
      .forEach(function(el) { el.textContent = '0.000'; });
    var tot = document.querySelector('.total-jobs-count');
    if (tot) tot.textContent = '0';
  });

  if (document.readyState === 'complete') {
    setTimeout(runAnimation, 300);
  } else {
    window.addEventListener('load', function() { setTimeout(runAnimation, 300); });
  }

  // Engine row scroll animation
  document.addEventListener('DOMContentLoaded', function() {
    var rows = document.querySelectorAll('.engine[data-engine-idx]');
    if (!rows.length) return;
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var el = entry.target;
          var i = parseInt(el.getAttribute('data-engine-idx') || 0);
          setTimeout(function() { el.classList.add('engine-visible'); }, i * 55);
          obs.unobserve(el);
        }
      });
    }, { threshold: 0.1 });
    rows.forEach(function(r) { obs.observe(r); });
  });
})();
</script>

