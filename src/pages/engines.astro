---
import BaseLayout from "../layouts/BaseLayout.astro";

const description = "Engines — Plain Theory Labs";
---

<BaseLayout title="Engines — Plain Theory Labs" description={description}>
  <div class="wrap">
    <div class="section">
      <span class="section-label">The framework</span>
      <div class="contact-body">
        <p>Full engine documentation is available in the docs, including technical specifications, scoring methodology, and data requirements for each engine.</p>
        <a href="/docs" class="contact-email">Read the documentation</a>
      </div>
    </div>
    <footer>
      <span>Plain Theory Labs</span>
      <span>2026</span>
    </footer>
  </div>
</BaseLayout>
