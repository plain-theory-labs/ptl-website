<svg
  class="ace-art"
  viewBox="0 0 820 360"
  role="img"
  aria-label="Sample ACE output: seven scheduler jobs scored by GPU utilization and routed to review queues"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- outer border -->
  <rect x="18" y="18" width="784" height="324" rx="16" fill="none" stroke="#d7d4cf" stroke-width="1.4" />

