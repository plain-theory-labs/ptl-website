  <text font-family="ui-monospace, monospace" font-size="10.5" fill="#9a948e" letter-spacing="0.06em" x="690" y="52">QUEUE</text>

  <!-- header separator -->
  <line x1="36" y1="63" x2="784" y2="63" stroke="#dedad5" stroke-width="1" />

  <!-- ROW 0: job_841203  util=2%  near_zero -->
  <rect x="192" y="74" width="420" height="16" rx="3" fill="#e8e4de" />
  <rect x="192" y="74" width="8.4" height="16" rx="2" fill="#c4a898" />
  <text font-family="ui-monospace, monospace" font-size="11.5" fill="#5c5652" x="44" y="86">job_841203</text>
  <text font-family="ui-monospace, monospace" font-size="11.5" fill="#8a5e54" text-anchor="end" x="660" y="86">2%</text>
  <text font-family="ui-monospace, monospace" font-size="11.5" fill="#8a5e54" x="690" y="86">near_zero</text>
  <line x1="36" y1="100" x2="784" y2="100" stroke="#edeae6" stroke-width="0.8" />

  <!-- ROW 1: job_841204  util=18%  review -->
  <rect x="192" y="110" width="420" height="16" rx="3" fill="#e8e4de" />
  <rect x="192" y="110" width="75.6" height="16" rx="3" fill="#8a9aaa" />
  <text font-family="ui-monospace, monospace" font-size="11.5" fill="#5c5652" x="44" y="122">job_841204</text>
  <text font-family="ui-monospace, monospace" font-size="11.5" fill="#5c6e7e" text-anchor="end" x="660" y="122">18%</text>
